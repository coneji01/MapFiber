<section class="section auth-section">
  <div class="container">
    <div class="auth-container">
      <div class="auth-card glass-card">
        <div class="auth-header">
          <span class="logo-text">Map<span class="text-cyan">Fiber</span></span>
          <h2>Iniciar Sesión</h2>
          <p>Accede a tu panel de control</p>
        </div>

        <% if (locals.error) { %>
          <div class="alert alert-error">
            <span class="alert-icon">⚠️</span>
            <span><%= error %></span>
          </div>
        <% } %>

        <form action="/web/auth/login" method="POST" class="auth-form">
          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input type="email" id="email" name="email" placeholder="tu@correo.com" required class="form-input">
          </div>
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required class="form-input">
          </div>
          <button type="submit" class="btn btn-primary btn-block">Iniciar Sesión</button>
        </form>

        <div class="auth-footer">
          <p>¿No tienes cuenta? <a href="/web/auth/register">Crear Cuenta</a></p>
        </div>
      </div>
    </div>
  </div>
</section>
